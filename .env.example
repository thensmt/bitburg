# Bitburg environment variables.
# Copy to .env.local for dev or configure in Vercel for prod.
# Every variable here is required unless marked (optional) or (Phase 2 / frozen).

# --- Database (Supabase PostgreSQL) ------------------------------------------
# Local dev: use the SESSION pooler (port 5432) for both URLs. It supports
# prepared statements and handles long-lived dev connections without tripping
# the Supavisor circuit breaker.
# Vercel prod: swap DATABASE_URL to the TRANSACTION pooler (port 6543) with
# ?pgbouncer=true — that's the serverless-optimized path.
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# --- Supabase client (used when calling Supabase APIs directly) --------------
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk (auth) ------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Svix signing secret for POST /api/webhooks/clerk
CLERK_WEBHOOK_SECRET=
# Redirect URLs (optional — have sensible defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# --- App URL (used in Stripe Connect redirect links) -------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe Connect (Phase 2 / frozen — required only if touching payments) --
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Cloud Storage (deferred — pros link external URLs for now) -------
# Tech stack review recommends migrating to Cloudflare R2 when uploads land.
GCS_BUCKET_NAME=bitburg-media
GCS_PROJECT_ID=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
